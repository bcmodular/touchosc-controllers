        <luaMethod luaMethodName="SavePattern" luaMethodCode="function SavePattern()&#10;    SendPatternDumpRequests()&#13;&#10;&#13;&#10;    if (patternStruct) then&#13;&#10;&#13;&#10;        local allPatternParams = table.concat(patternStruct)&#13;&#10;        local dataToWrite = MemoryBlock (allPatternParams)&#13;&#10;        local dataToWriteSize = dataToWrite:getSize()&#13;&#10;&#13;&#10;        --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, tostring(dataToWriteSize))&#13;&#10;        if dataToWriteSize &lt;= 0 then&#13;&#10;            --utils.warnWindow (&quot;Data to write&quot;, &quot;There is no data to write&quot;)&#13;&#10;            --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;There is no data to write&quot;)&#13;&#10;&#13;&#10;        elseif (dataToWriteSize == 196) then --only accept pattern dumps of this size&#13;&#10;            &#13;&#10;            fileToWrite = utils.saveFileWindow (&quot;Save Pattern&quot;, File.getSpecialLocation(File.userDesktopDirectory), &quot;*.syx&quot;, true)&#13;&#10;&#13;&#10;            if fileToWrite:hasWriteAccess() then&#10;&#13;&#10;                --fileToWrite:replaceFileContentWithData(dataToWrite)&#13;&#10;                if fileToWrite:replaceWithData(dataToWrite) == false then&#13;&#10;                    --utils.warnWindow (&quot;file write&quot;, &quot;Sorry, the editor failed to write the data to file&quot;)&#13;&#10;                    panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;The editor did not write the pattern to disk.&quot;)&#13;&#10;                else&#13;&#10;                    fileToWrite:replaceWithData(dataToWrite)&#13;&#10;                    fileToWrite:create()&#13;&#10;                end &#13;&#10;&#10;            end&#13;&#10;&#13;&#10;            if fileToWrite:existsAsFile() then&#13;&#10;                panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Saved the pattern to disk&quot;)&#13;&#10;            end&#13;&#10;        end&#13;&#10;    end&#13;&#10;    &#13;&#10;    for k in pairs (patternStruct) do &#13;&#10;        patternStruct[k] = nil &#13;&#10;    end&#13;&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="c6b176c280ce4e52a290be527ccb7384"
                   luaMethodValid="1"/>
      </luaMethodGroup>
