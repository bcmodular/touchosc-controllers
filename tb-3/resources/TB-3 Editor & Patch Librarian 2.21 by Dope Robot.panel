        <luaMethod luaMethodName="sysexReceiveMsg" luaMethodCode="sysexReceiveMsg = function (midiSysexData)&#10;&#9;-- Your method code here&#10;&#13;&#10;        PatchDataSYX = midiSysexData:getLuaData()&#13;&#10;console(&quot;MAKING SURE THIS IS CALLED&quot;)&#13;&#10;    s = midiSysexData:getMidiMessageType()&#13;&#10;    ss = midiSysexData:getSize()&#13;&#10;&#13;&#10;    panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Message type: &quot;..s)&#13;&#10;    panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Message size: &quot;..ss)&#13;&#10;&#13;&#10;end&#13;&#10;"
