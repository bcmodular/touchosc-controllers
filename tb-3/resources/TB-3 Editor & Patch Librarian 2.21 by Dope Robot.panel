x1Block:getByte(77), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1DelayFeedback&quot;):getComponent():setValue(fx1Block:getByte(78), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1DelayLpf&quot;):getComponent():setValue(fx1Block:getByte(79), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1DelayEffectLevel&quot;):getComponent():setValue(fx1Block:getByte(80), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1DelayDirectLevel&quot;):getComponent():setValue(fx1Block:getByte(81), false)&#13;&#10;&#9;&#9;    -- Pitch Shifter&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifterrSw&quot;):getComponent():setValue(fx1Block:getByte(82), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifterVoice&quot;):getComponent():setValue(fx1Block:getByte(83), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter1Pitch&quot;):getComponent():setValue(fx1Block:getByte(84), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter1PreDelay&quot;):getComponent():setValue(fx1Block:getByte(85), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifterFeedback&quot;):getComponent():setValue(fx1Block:getByte(86), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter1Level&quot;):getComponent():setValue(fx1Block:getByte(87), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter2Pitch&quot;):getComponent():setValue(fx1Block:getByte(88), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter2PreDelay&quot;):getComponent():setValue(fx1Block:getByte(89), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PitchShifter2Level&quot;):getComponent():setValue(fx1Block:getByte(91), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1PSDirectLevel&quot;):getComponent():setValue(fx1Block:getByte(92), false)&#13;&#10;&#9;&#9;    -- EQ&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqSw&quot;):getComponent():setValue(fx1Block:getByte(94), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqLowCut&quot;):getComponent():setValue(fx1Block:getByte(95), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqLowGain&quot;):getComponent():setValue(fx1Block:getByte(96), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqLowMidFreq&quot;):getComponent():setValue(fx1Block:getByte(97), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqLowMidQ&quot;):getComponent():setValue(fx1Block:getByte(98), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqLowMidGain&quot;):getComponent():setValue(fx1Block:getByte(99), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqHighMidFreq&quot;):getComponent():setValue(fx1Block:getByte(100), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqHighMidQ&quot;):getComponent():setValue(fx1Block:getByte(101), false)&#13;&#10;            panel:getModulatorByName(&quot;tb3Efx1EqHighMidGain&quot;):getComponent():setValue(fx1Block:getByte(102), false)&#13;&#10;            panel:getModulatorByName(&quot;tb3Efx1EqHighCut&quot;):getComponent():setValue(fx1Block:getByte(103), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Efx1EqHighGain&quot;):getComponent():setValue(fx1Block:getByte(104), false)&#13;&#10;&#13;&#10;&#9;        panel:sendMidiMessageNow(CtrlrMidiMessage(fx1Block))&#13;&#10;&#13;&#10;            panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Loaded the patch from disk&quot;)&#13;&#10;&#13;&#10;        else&#13;&#10;            panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Wrong file size&quot;) &#13;&#10;        end&#13;&#10;&#13;&#10;    else&#13;&#10;        --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;File does not exist&quot;)        &#13;&#10;    end&#13;&#10;&#13;&#10;    --now send the rest of the midi messages&#13;&#10;    --for some reason the fx1 and fx2 blocks have an issue if sent here, so i moved them above&#13;&#10; &#9;panel:sendMidiMessageNow(CtrlrMidiMessage(vcaBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(cvBlock))&#13;&#10;    panel:sendMidiMessageNow(CtrlrMidiMessage(dstBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(xmdBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(vcfBlock))&#13;&#10;    panel:sendMidiMessageNow(CtrlrMidiMessage(lfoBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(vcoBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(rngBlock))&#13;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(asnBlock))&#13;&#10;&#13;&#10;&#13;&#10;end&#13;&#10;&#13;&#10;    --PatchDataSettings = midiMessage:getData()&#13;&#10;    --a = panel:getModulatorByName(&quot;tb3VcaAttack&quot;):getValue()&#13;&#10;    --PatchDataSettings:setByte(11,a)&#13;&#10;    --a = panel:getModulatorByName(&quot;tb3VcaDecay&quot;):getValue()&#13;&#10;    --PatchDataSettings:setByte(12), a)&#13;&#10;&#13;&#10;        --LUA&gt;&gt; VCA section = 18 bytes. Full byte count is now:    18&#10;        --LUA&gt;&gt; CV offset section = 19 bytes. Full byte count is now: 37&#10;        --LUA&gt;&gt; Dstortion section = 22 bytes. Full byte count is now: 59&#10;        --LUA&gt;&gt; Cross Mod section = 23 bytes. Full byte count is now: 82&#10;        --LUA&gt;&gt; VCF section = 24 bytes. Full byte count is now: 106&#10;        --LUA&gt;&gt; LFO section = 26 bytes. Full byte count is now: 132&#10;        --LUA&gt;&gt; Ring Mod section 27 bytes. Full byte count is now: 159&#10;        --LUA&gt;&gt; VCO section 27 bytes. Full byte count is now: 186&#10;        --LUA&gt;&gt; Assign section = 31 bytes. Full byte count is now: 217&#10;        --LUA&gt;&gt; EFX2 section = 97 bytes. Full byte count is now: 314&#10;        --LUA&gt;&gt; EFX1 section = 108 bytes. Full byte count is now: 422"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="0f967392e8864656a28bf2a215b46b1c"
                   luaMethodValid="1"/>
        <luaMethod luaMethodName="SavePatch" luaMethodCode="function SavePatch()&#13;&#10;&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Save function has been accessed&quot;)&#13;&#10;&#13;&#10;    --call the dumprequests&#13;&#10;    SendPatchDumpRequests()&#13;&#10;&#13;&#10;    if (tableStruct) then&#13;&#10;&#13;&#10;        local allPatchParams = table.concat(tableStruct)&#13;&#10;        local dataToWrite = MemoryBlock (allPatchParams)&#13;&#10;        local dataToWriteSize = dataToWrite:getSize()&#13;&#10;&#13;&#10;        if dataToWriteSize &lt;= 0 then&#13;&#10;            --utils.warnWindow (&quot;Data to write&quot;, &quot;There is no data to write&quot;)&#13;&#10;            --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;There is no data to write&quot;)&#13;&#10;&#13;&#10;        elseif (dataToWriteSize == 422) then --only accept patch dumps of this size&#13;&#10;            &#13;&#10;            --fileToWrite = utils.saveFileWindow (&quot;Save Patch&quot;, File.getSpecialLocation(File.userHomeDirectory), &quot;*.syx&quot;, true)&#13;&#10;            fileToWrite = utils.saveFileWindow (&quot;Save Patch&quot;, File.getSpecialLocation(File.userDesktopDirectory), &quot;*.syx&quot;, true)&#13;&#10;&#13;&#10;            if fileToWrite:hasWriteAccess() then&#10;&#13;&#10;                --fileToWrite:replaceFileContentWithData(dataToWrite)&#13;&#10;                if fileToWrite:replaceWithData(dataToWrite) == false then&#13;&#10;                    --utils.warnWindow (&quot;file write&quot;, &quot;Sorry, the editor failed to write the data to file&quot;)&#13;&#10;                    panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;The editor did not write the file to disk.&quot;)&#13;&#10;                else&#13;&#10;                    fileToWrite:replaceWithData(dataToWrite)&#13;&#10;                    fileToWrite:create()&#13;&#10;                end &#13;&#10;&#10;            end&#13;&#10;&#13;&#10;            if fileToWrite:existsAsFile() then&#13;&#10;                panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Saved the file to disk&quot;)&#13;&#10;            end&#13;&#10;&#13;&#10;        end&#13;&#10;&#13;&#10;    end&#13;&#10;    &#13;&#10;    for k in pairs (tableStruct) do &#13;&#10;        tableStruct[k] = nil &#13;&#10;    end&#13;&#10;    &#13;&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="ba64a692e540477aa251271516c83d7e"
                   luaMethodValid="1"/>
        <luaMethod luaMethodName="loadFileAsData" luaMethodCode="function loadFileAsData()&#13;&#10;&#10;&#9;-- Your method code here&#13;&#10;&#13;&#10;    --code here for text info&#13;&#10;&#13;&#10;    --send sysexd info&#13;&#10;&#10;    --fileToRead = panel:getModulatorByName(&quot;&quot;):getComponent: getSelectedFile(0)&#13;&#10;&#13;&#10;    if fileToRead:existsAsFile() then&#13;&#10;&#13;&#10;        --create a memory block&#13;&#10;        --fileData = MemoryBlock(fileToRead:getSize())&#13;&#10;        --fileToRead:loadFileAsData(fileData)&#13;&#10;        &#13;&#10;&#13;&#10;        --now it might be possible to just send this to recieveMidiData&#13;&#10;        --recieveMidiData(fileData)&#13;&#10;    end&#13;&#10;&#13;&#10;end&#13;&#10;&#13;&#10; &#13;&#10;            --if fileToWrite:hasFileExtension(String (&quot;syx&quot;)) then&#10;                --this is stupid the File() should not be necessary but luabind does not handle type conversions well&#13;&#10;            --    fileToWrite = File (fileToWrite:withFileExtension(String (&quot;syx&quot;)))&#10;            --end&#13;&#10;&#13;&#10;        --testStuff = string.format(fx1Block:toHexString(1))  &#13;&#10;&#13;&#10;        --dataHex = fileToRead:toHexString(1)&#13;&#10;        --HexPrint = string.sub(dataHex, 1)--the full hex string&#13;&#10;&#13;&#10;        --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Write to memoryBlock: &quot;..dataToWriteSize)&#13;&#10;        --allPatchParams = table.concat(tableStruct, &quot; &quot;)&#13;&#10;        --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, string.format(allPatchParams))&#13;&#10;&#13;&#10;           --if fileToWrite:existsAsFile() then&#13;&#10;                --lastSavedProogrram = PatchDataLoaded&#13;&#10;                --programName = PatchDataLoaded:getRange(7,16)&#13;&#10;                --savedataPatchDataLoaded()&#13;&#10;                --f:replaceFileContentWithData(lastSavedProgram)&#13;&#10;                --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;saved the file to disk&quot;)&#13;&#10;            --end&#13;&#10;&#13;&#10;    --local exactBytes = byteCount&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Number of bytes: &quot;..string.format(exactBytes))&#13;&#10;    --local myExactBytes =     panel:getLabelComponent(&quot;tb3SavePatchButton&quot;):getPropertyString()&#13;&#10;    --local myExactBytes = &#13;&#10;    --check to see if slot 11-15 are empty&#13;&#10;        --if (tableStruct[11]) then&#13;&#10;        --    console(&quot;this is a full call&quot;)&#13;&#10;        --elseif (tableStruct[10]) then&#13;&#10;        --    console(&quot;this is the save patch call&quot;)&#13;&#10;        --else&#13;&#10;        --    console(&quot;neither eleven or twelve&quot;)&#13;&#10;        --end&#13;&#10;       &#13;&#10;    --f = utils.saveFileWindow (&quot;Save Patch&quot;, File.getSpecialLocation(File.userHomeDirectory), &quot;*.syx&quot;, true)&#13;&#10;    --f:replaceWithData(data)&#13;&#10;    --f:create()&#13;&#10;   -- if f:existsAsFile() then&#13;&#10;    --        lastSavedProogrram = PatchDataLoaded&#13;&#10;            --programName = PatchDataLoaded:getRange(7,16)&#13;&#10;            --savedataPatchDataLoaded()&#13;&#10;            --f:replaceFileContentWithData(lastSavedProgram)&#13;&#10;    --        panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;saved the file to disk&quot;)&#13;&#10;    --end&#13;&#10;&#13;&#10;        --if (allDataConcat) then&#13;&#10;        --    console(&quot;the table has values. Can I access byteCount here?  &quot;)&#13;&#10;        --    --string.format(byteCount)&#13;&#10;            &#13;&#10;        --else&#13;&#10;        --    console(&quot;somehow the table appears to be empty&quot;)&#13;&#10;        --end&#13;&#10;--function createDataTable()&#13;&#10;&#13;&#10;    --tableStruct = {}&#13;&#10;&#13;&#10;--end&#10;&#9;-- Your method code here&#13;&#10;&#13;&#10;    --now the machine should have returned some midi sysex strings. &#13;&#10;    --there should be a table created&#13;&#10;&#13;&#10;    --message = table.concat(tableStruct)&#13;&#10;    --console(message)&#13;&#10;&#13;&#10;    --it will receive 2 messages now, a receive messaeg, and then a reponse message&#13;&#10;    --this caauses receivemididata call to be called twice&#13;&#10;&#13;&#10;    --now i  have to compile these midi message responses into a single file&#13;&#10;    --and that's what i'll enter into the file save command below&#13;&#10;&#13;&#10;    --sss = panel:getGlobalVariable(savePatchMode)&#13;&#10;&#9;--panel:setGlobalVariable(,1)&#13;&#10;    --panel:getLabelComponent(&quot;save patch is: &quot;..sss)&#13;&#10;    --local strHeaderMidiData = string.sub(midiData:getData():toHexString(1), 1, 33)&#13;&#10;&#13;&#10;    --now that you've sent the request message(s), get the return value&#13;&#10;&#13;&#10;    --loccal dataToSave=MemoryBlock.fromLuaTable()&#13;&#10;    --data = panel:receiveMidiMessage()&#13;&#10;    --console(sub.str(data,1,0))&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Somehow i need to save a patch here&quot;)&#13;&#10;&#13;&#10;    --PatchDataSYX = midiSysexData:getLuaData()&#13;&#10;    --PatchDataReceived2 = midiData:getData()&#13;&#10;    --midiData:getLuaData():getByte(11)&#13;&#10;&#13;&#10;    --tableCounterVar = tableCounterVar + 1&#13;&#10;    --console(&quot;Somehow i need to save a patch here&quot;)&#13;&#10;    --data = panel:receiveMidiMessage()&#13;&#10;    --console(string.format(data))&#13;&#10;&#13;&#10;--..string.format(tableCounterVar))&#13;&#10;&#13;&#10;&#13;&#10;    --panel:setGlobalVariable(savePatchMode,0)&#13;&#10;&#13;&#10;    --clear the structure&#13;&#10;   --for k in pairs (tableStruct) do &#13;&#10;   --    tableStruct[k] = nil &#13;&#10;   --end&#13;&#10;&#13;&#10;   --the panel has just received a mid message of some kind. &#13;&#10;    --what type is it?&#13;&#10;    --PatchDataSYX = midiSysexData:getLuaData()&#13;&#10;&#9;--panel:setGlobalVariable(,1)&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;Message type: &quot;..s..&quot; \n Message size: &quot;..ss.. &quot;\n and save patch is: &quot;..sss)&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;save mode: &quot;..sss)&#13;&#10;    --console(SavePatchValueData)&#13;&#10;    --if (sss = 1) then&#13;&#10;    --concatanetate it into a variable?&#13;&#10;    -- panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;this is where you concaontenat&quot;)&#13;&#10;    --end&#13;&#10;    --console(HexPrint)&#13;&#10;    --parse the first 33 bytes to figure out which section has been received.&#13;&#10;    --an easier way might be to just determine the file size unless its 27. &#13;&#10;    --i = i + 1&#13;&#10;    --tableStruct[i] = HexPrint&#13;&#10;    --console(PatchData:toHexString(1))&#13;&#10;   -- tableCounterVar = tableCounterVar + 1&#13;&#10;    --if (tableCounterVar &lt;=10) then&#13;&#10;    --elseif (tableCounterVar &gt;= 10) then&#13;&#10;     --tableCounterVar = 0;&#13;&#10;    --end&#13;&#10;   --console(string.format(tableCounterVar))&#13;&#10;   -- message = table.concat(tableStruct)&#13;&#10;   -- console(message)&#13;&#10;    --the rest can be verfied by size&#13;&#10;    --local gottenSize = midiData:getSize()&#13;&#10;    --tableStruct[gottenSize] =  midiData:getData()&#13;&#10;    --panel:setGlobalVariable(tableCounterVar,tableCounterVar + 1)&#13;&#10;    --console(message)&#13;&#10;    --console(string.format(message))&#13;&#10;    --console(string.sub(midiData:getData():toHexString(1), 1))&#13;&#10;   --printable data&#13;&#10;    --HexPrint = string.sub(PatchHex, 1)&#13;&#10;    --sss = panel:getGlobalVariable(savePatchMode)&#13;&#10;    --concatValue = &quot; &quot; .. HexPrint&#13;&#10;    --console(concatValue)&#13;&#10;    --console(message)&#13;&#10;    --DEPRECATED  PatchDataReceived = midiData:getLuaData()&#13;&#10;    --maybe check for number of midi messages&#13;&#10;    --if 11 are sent, then write the file&#13;&#10;    --message = table.concat(tableStruct)&#13;&#10;    --vca = tableStruct[0]&#13;&#10;    --console(string.format(vca))&#13;&#10;    --console(string.sub(tableStruct[0],1 25))&#13;&#10;    --console(&quot;message type is &quot;..msgType)&#13;&#10;&#13;&#10;&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;size of the file: &quot;..fileData:getSize())&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;first returned byte &quot;..vcaBlock:getByte(11))&#13;&#10;    --fx2Stuff = string.format(asnBlock:toHexString(1))&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;does fx2 have values: &quot;..fx2Stuff)&#13;&#10;    --fx1Stuff = table.concat(fx1Block)&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;does fx2 have values: &quot;..fx1Stuff)&#13;&#10;&#13;&#10;&#13;&#10;    --vcaBlock&#13;&#10;--&#9;&#9;panel:getModulatorByName(&quot;tb3VcaAttack&quot;):getComponent():setValue(vcaBlock:getByte(11), false)&#13;&#10;--&#9;&#9;panel:getModulatorByName(&quot;tb3VcaDecay&quot;):getComponent():setValue(vcaBlock:getByte(12), false)&#13;&#10;--&#9;&#9;panel:getModulatorByName(&quot;tb3VcaSustain&quot;):getComponent():setValue(vcaBlock:getByte(13), false)&#13;&#10