        <luaMethod luaMethodName="LoadPattern" luaMethodCode="function LoadPattern()&#10;    fileToRead = utils.openFileWindow (&quot;Open Pattern&quot;, File(&quot;&quot;), &quot;*.syx&quot;, true)&#13;&#10;    &#13;&#10;    if fileToRead:existsAsFile() then&#13;&#10;&#13;&#10;        --this function should load and parse the data received from the requiest call&#13;&#10;        fileData = MemoryBlock(fileToRead:getSize())&#13;&#10;        fileToRead:loadFileAsData(fileData)&#13;&#10;&#13;&#10;        DataReceivedSize = fileData:getSize()&#13;&#10;        --console(&quot;size of file is: &quot;..string.format(DataReceivedSize))&#13;&#10;        --file size must be 196 or abort&#13;&#10;        if DataReceivedSize == 196 then&#13;&#10;        &#13;&#10;            --m = string.format(fileData:getByte(1))&#13;&#10;            settingBlock = fileData:getRange(0,16)&#13;&#10;            pitchBlock = fileData:getRange(16,45)&#13;&#10;            slideBlock = fileData:getRange(61,45)&#13;&#10;            gateBlock = fileData:getRange(106,45)&#13;&#10;            accentBlock = fileData:getRange(151,45)&#13;&#10;&#13;&#10;            --settingBlock&#13;&#10;&#9;        panel:getModulatorByName(&quot;tb3TripletTiming&quot;):getComponent():setValue(settingBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3NumSteps&quot;):getComponent():setValue(settingBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3GateTime&quot;):getComponent():setValue(settingBlock:getByte(13), false)&#13;&#10;&#13;&#10;            --pitchBlock&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step1PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(11), false)&#13;&#10;&#9;        panel:getModulatorByName(&quot;tb3Step2PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Step3PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(13), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step4PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(14), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step5PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(15), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step6PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(16), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step7PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(17), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step8PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(18), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step9PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(19), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Step10PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(20), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step11PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(21), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step12PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(22), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Step13PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(23), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step14PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(24), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step15PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(25), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Step16PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(26), false)&#13;&#10;    &#9;&#9;panel:getModulatorByName(&quot;tb3Step17PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(27), false)&#13;&#10;&#9;    &#9;panel:getModulatorByName(&quot;tb3Step18PitchValue&quot;):getComponent():setValue(pitchBlock:getByte(28), false)&#13;