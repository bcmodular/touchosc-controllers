        <luaMethod luaMethodName="receiveModValueChange" luaMethodCode="--&#10;-- Called when any modulator changes on the panel&#10;--&#10;-- @program modulator that changed&#10;-- @value new modulator value&#10;--&#10;&#10;receiveModValueChange = function( modulator,  value)&#13;&#10;&#13;&#10;    --find out what modulator is sending something&#13;&#10;    --console(modulator)&#13;&#10;    --console(&quot;getting here&quot;)&#13;&#10;&#13;&#10;&#10;end&#13;&#10;&#13;&#10;&#13;&#10;--receiveModValueChange = function(modulator, midiData)&#13;&#10;&#10;&#9;--local strHeaderMidiData = string.sub(midiData:getData():toHexString(1), 1, 33)&#13;&#10;    --console(strHeaderMidiData)&#13;&#10;--&#9;if (strHeaderMidiData == &quot;f0 41 10 00 00 7b 12 10 00 00 00 &quot; ) then -- LFO&#13;&#10;&#13;&#10;--&#9;end&#13;&#10;&#13;&#10;--end&#13;&#10;"
