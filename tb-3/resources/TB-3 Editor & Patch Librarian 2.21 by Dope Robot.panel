        <luaMethod luaMethodName="setPatameterToEffect" luaMethodCode="function setPatameterToEffect()&#13;&#10;&#9;local pId = panel:getGlobalVariable(3) - 1000&#13;&#10;    --console(&quot;Debug: pId = &quot;..pId)&#13;&#10;&#9;if pId &gt;=0 and pId &lt;= 255 then&#13;&#10;&#9;&#9;tb3SendSysEx2Bytes(0x10, 0x00, 0x14, 0x06, pId)&#13;&#10;&#9;&#9;panel:getLabelComponent(&quot;tb3ParameterEffect&quot;):setText(parameterIdTable[pId+1])&#13;&#10;&#9;else&#13;&#10; &#9;&#9;panel:getLabelComponent(&quot;tb3ParameterEffect&quot;):setText(&quot;&quot;)       &#13;&#10;    end&#13;&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="199029e15bb34dc8979e6b43cfcee877"
                   luaMethodValid="1"/>
        <luaMethod luaMethodName="tb3SendSysEx2Bytes" luaMethodCode="function tb3SendSysEx2Bytes(a1, a2, a3, a4, value)&#10;&#9;local iMSB, iLsb, iCheckSum&#10;&#9;local midiDataToSend = MemoryBlock( { 0xf0, 0x41, 0x10, 0x00, 0x00, 0x7b, 0x12, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xf7 } )&#10;&#10;&#9;iMsb = math.floor(value / 16)&#10;&#9;iLsb = value % 16&#10;&#9;iCheckSum = (0x100 - ((a1 + a2 + a3 + a4 + iMsb + iLsb) % 256)) % 128&#13;&#10;&#13;&#10;  console(&quot;This is the parameter ID being assigned: iMsb = &quot;..iMsb..&quot;, iLsb =&quot;..iLsb)&#13;&#10;  console(&quot;This is the parameter ID being assigned: &quot;..value)&#13;&#10;&#13;&#10;&#9;midiDataToSend:setByte( 7, a1)&#10;&#9;midiDataToSend:setByte( 8, a2)&#10;&#9;midiDataToSend:setByte( 9, a3)&#10;&#9;midiDataToSend:setByte(10, a4)&#10;&#9;midiDataToSend:setByte(11, iMsb)&#10;&#9;midiDataToSend:setByte(12, iLsb)&#10;&#9;midiDataToSend:setByte(13, iCheckSum)&#10;&#10;&#9;panel:sendMidiMessageNow(CtrlrMidiMessage(midiDataToSend:toHexString(1)))&#10;--&#9;console(midiDataToSend:toHexString(1))&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="af2aab3db45940d4bc998cf044d78fce"
                   luaMethodValid="1"/>
        <luaMethod luaMethodName="setParamToPadX" luaMethodCode="function setParamToPadX()&#10;&#9;local pId = panel:getGlobalVariable(3) - 1000&#13;&#10;&#9;if pId &gt;=0 and pId &lt;= 255 then&#13;&#10;&#9;&#9;tb3SendSysEx2Bytes(0x10, 0x00, 0x14, 0x08, pId)&#13;&#10;&#9;&#9;panel:getLabelComponent(&quot;tb3ParameterPadX&quot;):setText(parameterIdTable[pId+1])&#13;&#10;&#9;else&#13;&#10; &#9;--&#9;panel:getLabelComponent(&quot;tb3ParameterPadX&quot;):setText(&quot;&quot;)     &#13;&#10;&#9;&#9;&#9;panel:getLabelComponent(&quot;tb3ParameterAssignLabel&quot;):setText(String(pId+1))&#13;&#10;  &#13;&#10;    end&#13;&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="f9d9c94d0ae647ef884f2025298a8d99"
                   luaMethodValid="1"/>
