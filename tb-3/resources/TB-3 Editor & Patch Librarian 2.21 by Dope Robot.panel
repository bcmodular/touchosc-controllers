                   luaMethodValid="1"/>
        <luaMethod luaMethodName="DumpReceive" luaMethodCode="--function DumpReceive()&#10;&#9;-- Your method code here&#10;--end&#13;&#10;&#13;&#10;FULLAccountingRequestMsg  =         &quot;F0 41 10 00 00 7B 11 10 00 00 00 00 00 00 0D 63 F7 F0 41 10 00 00 7B 11 10 00 02 00 00 00 00 06 68 F7 F0 41 10 00 00 7B 11 10 00 04 00 00 00 00 0A 62 F7 F0 41 10 00 00 7B 11 10 00 06 00 00 00 00 0E 5C F7 F0 41 10 00 00 7B 11 10 00 08 00 00 00 00 0E 5A F7 F0 41 10 00 00 7B 11 10 00 0A 00 00 00 00 0B 5B F7 F0 41 10 00 00 7B 11 10 00 0C 00 00 00 00 05 5F F7 F0 41 10 00 00 7B 11 10 00 0E 00 00 00 00 09 59 F7 F0 41 10 00 00 7B 11 10 00 10 00 00 00 00 5F 01 F7 F0 41 10 00 00 7B 11 10 00 12 00 00 00 00 54 0A F7 F0 41 10 00 00 7B 11 10 00 14 00 00 00 00 12 4A F7 F0 41 10 00 00 7B 11 01 00 00 00 00 00 00 03 7C F7 F0 41 10 00 00 7B 11 30 00 00 00 00 00 00 03 4D F7 F0 41 10 00 00 7B 11 30 00 02 00 00 00 00 32 1C F7 F0 41 10 00 00 7B 11 30 00 04 00 00 00 00 20 2C F7 F0 41 10 00 00 7B 11 30 00 06 00 00 00 00 20 2A F7 F0 41 10 00 00 7B 11 30 00 08 00 00 00 00 20 28 F7&quot;&#13;&#10;&#13;&#10;noPatternSoundOnlyRequestMsg  =     &quot;F0 41 10 00 00 7B 11 10 00 00 00 00 00 00 0D 63 F7 F0 41 10 00 00 7B 11 10 00 02 00 00 00 00 06 68 F7 F0 41 10 00 00 7B 11 10 00 04 00 00 00 00 0A 62 F7 F0 41 10 00 00 7B 11 10 00 06 00 00 00 00 0E 5C F7 F0 41 10 00 00 7B 11 10 00 08 00 00 00 00 0E 5A F7 F0 41 10 00 00 7B 11 10 00 0A 00 00 00 00 0B 5B F7 F0 41 10 00 00 7B 11 10 00 0C 00 00 00 00 05 5F F7 F0 41 10 00 00 7B 11 10 00 0E 00 00 00 00 09 59 F7 F0 41 10 00 00 7B 11 10 00 10 00 00 00 00 5F 01 F7 F0 41 10 00 00 7B 11 10 00 12 00 00 00 00 54 0A F7 F0 41 10 00 00 7B 11 10 00 14 00 00 00 00 12 4A F7 F0 41 10 00 00 7B 11 01 00 00 00 00 00 00 03 7C F7&quot;&#13;&#10;&#13;&#10;function DumpReceive()&#10;&#9;-- Your method code here&#13;&#10;&#13;&#10;&#13;&#10;--    CtrlrMidiMessage(FULLAccountingRequestMsg)&#13;&#10;   -- CtrlrMidiMessage(noPatternSoundOnlyRequestMsg)&#13;&#10;&#13;&#10;    --local vcfData = string.sub(midiData:getData():toHexString(1), 1, 100)&#13;&#10; --   console(&quot;all data: &quot;..vcfData)&#13;&#10;--console(&quot;i should receive the dumped data here &quot;)&#13;&#10;--&#9;console(midiData:getData():toHexString(1)) &#13;&#10;&#13;&#10;--the panel sends the full sysex string&#13;&#10;--so this should parse the return value&#13;&#10;&#13;&#10;--&#9;CtrlrMidiMessage(patternAccentMessage)&#13;&#10;&#10;end"
                   luaMethodLinkedProperty="" luaMethodSource="0" uuid="47c41b72d7344c08a74227d8bdcb9d0d"
                   luaMethodValid="1"/>
        <luaMethod luaMethodName="LoadPatch" luaMethodCode="function LoadPatch()&#13;&#10;&#13;&#10;    --panel:getLabelComponent(&quot;tb3SysexLoadMessage&quot;):setPropertyString(&quot;uiLabelText&quot;, &quot;LOAD function has been accessed&quot;)&#13;&#10;    fileToRead = utils.openFileWindow (&quot;Open Patch&quot;, File(&quot;&quot;), &quot;*.syx&quot;, true)&#13;&#10;    &#13;&#10;    if fileToRead:existsAsFile() then&#13;&#10;&#13;&#10;        --this function should load and parse the data received from the requiest call&#13;&#10;        fileData = MemoryBlock(fileToRead:getSize())&#13;&#10;        fileToRead:loadFileAsData(fileData)&#13;&#10;&#13;&#10;        DataReceivedSize = fileData:getSize()&#13;&#10;        --console(&quot;size of file is: &quot;..string.format(DataReceivedSize))&#13;&#10;        --file size must be 422 or abort&#13;&#10;        if DataReceivedSize == 422 then&#13;&#10;        &#13;&#10;            --m = string.format(fileData:getByte(1))&#13;&#10;            vcaBlock = fileData:getRange(0,18)&#13;&#10;            cvBlock = fileData:getRange(18,19)&#13;&#10;            dstBlock = fileData:getRange(37,22)&#13;&#10;            xmdBlock = fileData:getRange(59,23)&#13;&#10;            vcfBlock = fileData:getRange(82,24)&#13;&#10;            lfoBlock = fileData:getRange(106,26)&#13;&#10;            vcoBlock = fileData:getRange(132,27)&#13;&#10;            rngBlock = fileData:getRange(159,27)&#13;&#10;            asnBlock = fileData:getRange(186,31)&#13;&#10;            fx2Block = fileData:getRange(217,97)&#13;&#10;            fx1Block = fileData:getRange(314,108)&#13;&#10;            --console(&quot;size of fx1Block is: &quot;..string.format(fx1Block:getSize()))&#13;&#10;&#13;&#10;            --vcaBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcaAttack&quot;):getComponent():setValue(vcaBlock:getByte(11), false)&#13;&#10;            --or you can do it this way&#13;&#10;            --fileData:setByte(11,panel:getModulatorByName(&quot;tb3VcaAttack&quot;):getValue())&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcaDecay&quot;):getComponent():setValue(vcaBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcaSustain&quot;):getComponent():setValue(vcaBlock:getByte(13), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcaRelease&quot;):getComponent():setValue(vcaBlock:getByte(14), false)&#13;&#10; &#9;&#9;    panel:getModulatorByName(&quot;tb3MasterVolume&quot;):getComponent():setValue(vcaBlock:getByte(15), false)  &#13;&#10;&#13;&#10;            --cvBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3OffsetSaw&quot;):getComponent():setValue(cvBlock:getByte(11)*16+cvBlock:getByte(12)-127, false)    &#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3OffsetSqr&quot;):getComponent():setValue(cvBlock:getByte(13)*16+cvBlock:getByte(14)-127, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3OffsetRing&quot;):getComponent():setValue(cvBlock:getByte(15)*16+cvBlock:getByte(16)-127, false)&#13;&#10;  &#13;&#10;            --dstBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionSwitch&quot;):getComponent():setValue(dstBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionType&quot;):getComponent():setValue(dstBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionDrive&quot;):getComponent():setValue(dstBlock:getByte(13), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionBottom&quot;):getComponent():setValue(dstBlock:getByte(14), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionTone&quot;):getComponent():setValue(dstBlock:getByte(15), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionEffectLevel&quot;):getComponent():setValue(dstBlock:getByte(16), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionDryLevel&quot;):getComponent():setValue(dstBlock:getByte(17), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3DistortionColor&quot;):getComponent():setValue(dstBlock:getByte(18), false)&#13;&#10;&#13;&#10;            --xmdBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossSqrSaw&quot;):getComponent():setValue(xmdBlock:getByte(11)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossSawSaw&quot;):getComponent():setValue(xmdBlock:getByte(13)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossWNSaw&quot;):getComponent():setValue(xmdBlock:getByte(14)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossPNSaw&quot;):getComponent():setValue(xmdBlock:getByte(15)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossSqrSqr&quot;):getComponent():setValue(xmdBlock:getByte(16)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossSawSqr&quot;):getComponent():setValue(xmdBlock:getByte(18)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossWNSqr&quot;):getComponent():setValue(xmdBlock:getByte(19)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3CrossPNSqr&quot;):getComponent():setValue(xmdBlock:getByte(20)-64, false)&#13;&#10;&#13;&#10;            --vcfBlock&#13;&#10;            vcfVal = vcfBlock:getByte(11)*16+vcfBlock:getByte(12)&#13;&#10;            resVal = vcfBlock:getByte(13)*16+vcfBlock:getByte(14)&#13;&#10;            modVal = vcfBlock:getByte(15)*16+vcfBlock:getByte(16)&#13;&#10;&#13;&#10;            --front panel takes precedence (cutoff, resonance)&#13;&#10;            panel:getModulatorByName(&quot;tb3VcfCutoff&quot;):getComponent():setValue(vcfVal, false)&#13;&#10;&#9;        panel:getModulatorByName(&quot;tb3VcfResonance&quot;):getComponent():setValue(resVal, false)&#13;&#10;&#9;        panel:getModulatorByName(&quot;tb3VcfModEnv&quot;):getComponent():setValue(modVal, false)&#9;&#9;&#13;&#10;            panel:getModulatorByName(&quot;tb3VcfAttack&quot;):getComponent():setValue(vcfBlock:getByte(17), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcfDecay&quot;):getComponent():setValue(vcfBlock:getByte(18), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcfSustain&quot;):getComponent():setValue(vcfBlock:getByte(19), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcfRelease&quot;):getComponent():setValue(vcfBlock:getByte(20), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcfKeyFollow&quot;):getComponent():setValue(vcfBlock:getByte(21), false)&#13;&#10;&#13;&#10;            --lfoBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoRate&quot;):getComponent():setValue(lfoBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoDelay&quot;):getComponent():setValue(lfoBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoSaw&quot;):getComponent():setValue(lfoBlock:getByte(13), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoSqr&quot;):getComponent():setValue(lfoBlock:getByte(14), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoTri&quot;):getComponent():setValue(lfoBlock:getByte(15), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoSin&quot;):getComponent():setValue(lfoBlock:getByte(16), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3OffsetLfo&quot;):getComponent():setValue(lfoBlock:getByte(17), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoSah&quot;):getComponent():setValue(lfoBlock:getByte(18), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoVcoDepth&quot;):getComponent():setValue(lfoBlock:getByte(19)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoVcfDepth&quot;):getComponent():setValue(lfoBlock:getByte(20)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoVcaDepth&quot;):getComponent():setValue(lfoBlock:getByte(21)-64, false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoBpmSyncSw&quot;):getComponent():setValue(lfoBlock:getByte(22), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3LfoRetrigger&quot;):getComponent():setValue(lfoBlock:getByte(23), false)&#13;&#10;&#13;&#10;            --vcoBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSawLevel&quot;):getComponent():setValue(vcoBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSQRLevel&quot;):getComponent():setValue(vcoBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSinLevel&quot;):getComponent():setValue(vcoBlock:getByte(15), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoWhitenoiseLevel&quot;):getComponent():setValue(vcoBlock:getByte(16), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoPinknoiseLevel&quot;):getComponent():setValue(vcoBlock:getByte(17), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoRingLevel&quot;):getComponent():setValue(vcoBlock:getByte(18), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSawSw&quot;):getComponent():setValue(vcoBlock:getByte(19), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSqrSw&quot;):getComponent():setValue(vcoBlock:getByte(20), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoSinSw&quot;):getComponent():setValue(vcoBlock:getByte(21), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoWhitenoiseSw&quot;):getComponent():setValue(vcoBlock:getByte(22), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoPinknoiseSw&quot;):getComponent():setValue(vcoBlock:getByte(23), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3VcoRingSw&quot;):getComponent():setValue(vcoBlock:getByte(24), false)&#13;&#10;&#13;&#10;            --rngBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3RingSaw&quot;):getComponent():setValue(rngBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3RingSqr&quot;):getComponent():setValue(rngBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Ring3rd&quot;):getComponent():setValue(rngBlock:getByte(15), false)&#13;&#10;&#9;        panel:getModulatorByName(&quot;tb3RingWhiteNoise&quot;):getComponent():setValue(rngBlock:getByte(16), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3RingPinkNoise&quot;):getComponent():setValue(rngBlock:getByte(17), false)&#13;&#10;            panel:getModulatorByName(&quot;tb3RingModX7&quot;):getComponent():setValue(rngBlock:getByte(22), false)&#13;&#10;&#13;&#10;            --asnBlock&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3PortaSw&quot;):getComponent():setValue(asnBlock:getByte(11), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3PortaTime&quot;):getComponent():setValue(asnBlock:getByte(12), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3PortaMode&quot;):getComponent():setValue(asnBlock:getByte(13), false)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3BenderRange&quot;):getComponent():setValue(asnBlock:getByte(14), false)&#13;&#10;            --set the text to the corresponding parameter from the table&#13;&#10;&#9;&#9;    panel:getLabelComponent(&quot;tb3ParameterPadZ&quot;):setText(parameterIdTable[asnBlock:getByte(15)*16+asnBlock:getByte(16)+1])&#13;&#10;&#9;&#9;    panel:getLabelComponent(&quot;tb3ParameterEffect&quot;):setText(parameterIdTable[asnBlock:getByte(17)*16+asnBlock:getByte(18)+1])&#13;&#10;&#9;&#9;    panel:getLabelComponent(&quot;tb3ParameterPadX&quot;):setText(parameterIdTable[asnBlock:getByte(19)*16+asnBlock:getByte(20)+1])&#13;&#10;&#9;&#9;    panel:getLabelComponent(&quot;tb3ParameterPadY&quot;):setText(parameterIdTable[asnBlock:getByte(21)*16+asnBlock:getByte(22)+1])&#13;&#10;            --front panel takes precedence (accent)&#13;&#10;&#9;&#9;    panel:getModulatorByName(&quot;tb3Accent&quot;):getComponent():setValue(asnBlock:getByte(25)*16+asnBlock:get